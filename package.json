{
  "name": "git-diff-action",
  "version": "0.0.0",
  "private": true,
  "description": "A GitHub Action for gathering the git diff of a pull request in JSON format",
  "main": "src/main.js",
  "scripts": {
    "format": "prettier --write '**/*.js'",
    "format-check": "prettier --check '**/*.js'",
    "lint": "eslint src/**/*.js",
    "package": "NODE_OPTIONS=--openssl-legacy-provider ncc build src/main.js -o dist --source-map --license licenses.txt",
    "test": "GIT_DIFF_JEST_TEST=true jest; test_exit=$?; make-coverage-badge --output-path ./badges/coverage.svg >/dev/null 2>&1 || echo 'coverage badge update skipped'; exit $test_exit",
    "ci-test": "GIT_DIFF_JEST_TEST=true jest",
    "all": "npm run format && npm run lint && npm run package",
    "bundle": "npm run format && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GrantBirki/git-diff.git"
  },
  "keywords": [
    "actions",
    "git",
    "diff",
    "ci"
  ],
  "author": "Grant Birkinbine",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "dedent-js": "^1.0.1",
    "js-yaml": "^4.1.1",
    "parse-git-diff": "^0.0.20"
  },
  "jest": {
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**"
    ],
    "moduleNameMapper": {
      "^@actions/core$": "<rootDir>/test-support/actions-core.js"
    },
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "@types/node": "^25.3.3",
    "@vercel/ncc": "^0.38.4",
    "@babel/preset-env": "^7.29.0",
    "eslint": "^10.0.2",
    "eslint-plugin-jest": "^29.15.0",
    "jest": "^30.2.0",
    "@babel/core": "^7.29.0",
    "babel-jest": "^30.2.0",
    "prettier": "^3.8.1",
    "make-coverage-badge": "^1.2.0"
  }
}
